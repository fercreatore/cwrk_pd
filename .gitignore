*.zip
*.docx
*.csv

# Allow specific docs
!_docs/*.docx
!_excel_pedidos/*.xlsx

# Streamlit
.streamlit/secrets.toml

# IDE
.idea/
.vscode/
*.swp
*.swo

# Heavy binary directories (PDFs, catálogos, imágenes de proveedores)
compras/
_archivo/
valijas/imagenes/
*.pdf
!_docs/*.pdf

# Embedded repos
clz_wpu/

# Sensitive
.env
credentials.json
